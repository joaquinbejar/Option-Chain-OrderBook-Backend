# PostgreSQL Configuration
POSTGRES_USER=orderbook
POSTGRES_PASSWORD=orderbook_secret
POSTGRES_DB=orderbook
POSTGRES_PORT=5432

# Database URL (for SQLx)
DATABASE_URL=postgres://orderbook:orderbook_secret@localhost:5432/orderbook

# API Configuration
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,tower_http=debug

# Authentication (JWT signed with an x509 key pair)
# Paths to the PEM-encoded RSA private key and x509 certificate. For local dev
# the built-in fixtures under tests/fixtures/ are used when these are unset; in
# production point these at your real (gitignored) key/cert files.
AUTH_PRIVATE_KEY_PATH=tests/fixtures/dev-private-key.pem
AUTH_CERT_PATH=tests/fixtures/dev-cert.pem
# Token issuer (the `iss` claim) and default token lifetime in seconds.
AUTH_ISSUER=option-chain-orderbook-backend
AUTH_DEFAULT_TTL_SECS=3600
# Operator secret gating POST /api/v1/auth/token. When unset, the endpoint is
# disabled and tokens must be minted with the `mint-token` CLI subcommand.
# Generate a strong random value in production; never commit the real secret.
AUTH_BOOTSTRAP_SECRET=change-me-dev-bootstrap-secret
# The server refuses to start with the committed DEV key pair unless this is set
# to 1 (local development only). Production MUST provide real key/cert paths
# instead of setting this.
ALLOW_DEV_KEY=1
